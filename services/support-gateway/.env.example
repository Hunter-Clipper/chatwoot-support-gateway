# Port the gateway itself listens on
PORT=4000

# Base URL of the Chatwoot instance (internal network address, not the public proxy hostname)
CHATWOOT_BASE_URL=http://localhost:3005

# Chatwoot account ID this gateway operates against
CHATWOOT_ACCOUNT_ID=1

# POC-only: a single Chatwoot personal API access token (Profile Settings -> Access Token).
# Per the integration spec section 7.3, a single token is acceptable for an early proof of
# concept but must be replaced with per-agent tokens (via ProviderIdentityService) before
# production. Do not commit the real value.
CHATWOOT_API_TOKEN=replace_with_real_token
CHATWOOT_WEBHOOK_SECRETS={"tenant-a": "replace_with_real_secret"}
CHATWOOT_AGENT_TOKENS={"stub-user": "replace_with_a_real_agent_token"}
CHATWOOT_TENANT_ACCOUNTS={"tenant-a": 1}

# Inbox new gateway-originated tickets get created against, per tenant (POST /support/conversations).
# IMPORTANT: point this at an API-channel inbox, not a real Channel::Email inbox, if that email
# inbox's outgoing SMTP and the same mailbox's inbound IMAP polling both point at one real
# mailbox (common in a small test/staging setup). A ticket-creation call posts its first message
# as "outgoing" - on a real email channel that triggers an actual SMTP send, and a bounce for a
# bad/fake contact address comes right back into the same polled mailbox as a brand-new
# "undeliverable" ticket. Found this the hard way when automated test runs were visibly
# cluttering a real support inbox with bounce-generated tickets.
CHATWOOT_TENANT_DEFAULT_INBOX={"tenant-a": 1}

# Optional - which agent identity (a key in CHATWOOT_AGENT_TOKENS) scheduled reconciliation
# runs as, per tenant. A tenant with no entry here just isn't reconciled on a schedule (still
# reachable on-demand via POST /internal/support/reconciliation).
CHATWOOT_RECONCILIATION_ACTORS={"tenant-a": "stub-user"}

SESSION_SIGNING_SECRET=replace_with_a_random_secret

# Optional - local read model + webhook dedup storage (default shown)
# DATABASE_PATH=./data/gateway.sqlite

# Optional - gateway-level rate limiting, per client IP (defaults shown)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=600

# Optional - how often scheduled reconciliation runs, in ms (default shown). 0 disables the
# scheduler entirely; on-demand reconciliation via the route still works either way.
# RECONCILIATION_INTERVAL_MS=300000
